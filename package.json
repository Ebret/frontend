{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node scripts/run-tests.js unit",
    "test:watch": "node scripts/run-tests.js unit --watch",
    "test:integration": "node scripts/run-tests.js integration",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:all": "node scripts/run-tests.js all && cypress run",
    "test:coverage": "node scripts/run-tests.js all --coverage",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "analyze": "cross-env ANALYZE=true next build",
    "deploy:staging": "vercel",
    "deploy:production": "vercel --prod",
    "docs": "docsify serve docs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.2",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.7.0",
    "chart.js": "^4.4.9",
    "next": "15.3.1",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@cypress/react": "^9.0.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "^14.3.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.7.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
