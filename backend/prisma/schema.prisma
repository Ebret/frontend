// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id                   Int               @id @default(autoincrement())
  email                String            @unique
  password             String
  firstName            String
  lastName             String
  role                 UserRole
  status               UserStatus        @default(ACTIVE)
  phoneNumber          String?
  address              String?
  profileImage         String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  memberId             String?           @unique
  memberSince          DateTime?
  loans                Loan[]
  savings              Savings[]
  transactions         Transaction[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  loanApplications     LoanApplication[]
  reviewedApplications LoanApplication[] @relation("LoanReviewer")
  loanHistoryActions   LoanHistory[]
  cooperativeId        Int?
  cooperative          Cooperative?      @relation(fields: [cooperativeId], references: [id])
  // Damayan relations
  damayanContributions      DamayanContribution[]
  damayanAssistanceRequests DamayanAssistance[]
  damayanApprovals          DamayanAssistance[]  @relation("DamayanApprover")
  damayanSettings           DamayanUserSettings?
  createdDamayanFunds       DamayanFund[]        @relation("FundCreator")
}

// Cooperative model for white-labeling
model Cooperative {
  id                 Int                     @id @default(autoincrement())
  name               String
  code               String                  @unique
  profileType        CooperativeProfileType?
  registrationNo     String?
  registrationDate   DateTime?
  hasCTE             Boolean                 @default(false)
  assetSizeClass     AssetSizeClass?
  logo               String?
  primaryColor       String?
  secondaryColor     String?
  address            String?
  phoneNumber        String?
  email              String?
  website            String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  users              User[]
  loans              Loan[]
  savings            Savings[]
  transactions       Transaction[]
  loanProducts       LoanProduct[]
  savingsProducts    SavingsProduct[]
  loanApplications   LoanApplication[]
  delinquencyReports DelinquencyReport[]
  performanceReports LoanPerformanceReport[]
  // Damayan relations
  damayanFunds       DamayanFund[]
  complianceFilings  ComplianceFiling[]
  complianceProfiles ComplianceAuthorizedRep[]
}

// Loan model
model Loan {
  id                 Int               @id @default(autoincrement())
  loanNumber         String            @unique
  userId             Int
  user               User              @relation(fields: [userId], references: [id])
  amount             Float
  interestRate       Float
  term               Int // in months
  status             LoanStatus        @default(PENDING)
  purpose            String?
  applicationDate    DateTime          @default(now())
  approvalDate       DateTime?
  disbursementDate   DateTime?
  maturityDate       DateTime?
  remainingPrincipal Float?
  nextPaymentDue     DateTime?
  totalPrincipalPaid Float?            @default(0)
  totalInterestPaid  Float?            @default(0)
  totalPenaltiesPaid Float?            @default(0)
  paymentsMade       Int?              @default(0)
  lateFeeAmount      Float?            @default(500)
  gracePeriod        Int?              @default(3)
  payments           Payment[]
  documents          Document[]
  paymentSchedule    PaymentSchedule[]
  loanHistory        LoanHistory[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  loanProductId      Int
  loanProduct        LoanProduct       @relation(fields: [loanProductId], references: [id])
  cooperativeId      Int?
  cooperative        Cooperative?      @relation(fields: [cooperativeId], references: [id])
}

// Loan Product model
model LoanProduct {
  id               Int               @id @default(autoincrement())
  name             String
  description      String?
  minAmount        Float
  maxAmount        Float
  interestRate     Float
  minTerm          Int // in months
  maxTerm          Int // in months
  processingFee    Float?
  requirements     String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  loans            Loan[]
  loanApplications LoanApplication[]
  cooperativeId    Int?
  cooperative      Cooperative?      @relation(fields: [cooperativeId], references: [id])
}

// Payment model
model Payment {
  id                   Int              @id @default(autoincrement())
  loanId               Int
  loan                 Loan             @relation(fields: [loanId], references: [id])
  amount               Float
  principalAmount      Float?
  interestAmount       Float?
  penaltyAmount        Float?           @default(0)
  paymentDate          DateTime
  scheduledPaymentDate DateTime?
  isLate               Boolean?         @default(false)
  paymentMethod        PaymentMethod
  referenceNumber      String?
  status               PaymentStatus    @default(PENDING)
  paymentScheduleItem  PaymentSchedule?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

// Savings model
model Savings {
  id               Int            @id @default(autoincrement())
  accountNumber    String         @unique
  userId           Int
  user             User           @relation(fields: [userId], references: [id])
  balance          Float          @default(0)
  savingsType      SavingsType
  status           SavingsStatus  @default(ACTIVE)
  transactions     Transaction[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  savingsProductId Int
  savingsProduct   SavingsProduct @relation(fields: [savingsProductId], references: [id])
  cooperativeId    Int?
  cooperative      Cooperative?   @relation(fields: [cooperativeId], references: [id])
}

// Savings Product model
model SavingsProduct {
  id              Int          @id @default(autoincrement())
  name            String
  description     String?
  interestRate    Float
  minimumBalance  Float
  withdrawalLimit Float?
  withdrawalFee   Float?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  savings         Savings[]
  cooperativeId   Int?
  cooperative     Cooperative? @relation(fields: [cooperativeId], references: [id])
}

// Transaction model
model Transaction {
  id                 Int                 @id @default(autoincrement())
  transactionType    TransactionType
  amount             Float
  description        String?
  referenceNumber    String              @unique
  userId             Int
  user               User                @relation(fields: [userId], references: [id])
  savingsId          Int?
  savings            Savings?            @relation(fields: [savingsId], references: [id])
  status             TransactionStatus   @default(PENDING)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cooperativeId      Int?
  cooperative        Cooperative?        @relation(fields: [cooperativeId], references: [id])
  // Damayan relations
  damayanContribution DamayanContribution?
  damayanAssistance   DamayanAssistance?
}

// Document model
model Document {
  id           Int          @id @default(autoincrement())
  name         String
  fileUrl      String
  documentType DocumentType
  loanId       Int?
  loan         Loan?        @relation(fields: [loanId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Notification model
model Notification {
  id               Int              @id @default(autoincrement())
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  title            String
  message          String
  isRead           Boolean          @default(false)
  notificationType NotificationType
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Audit Log model
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// Payment Schedule model
model PaymentSchedule {
  id                 Int      @id @default(autoincrement())
  loanId             Int
  loan               Loan     @relation(fields: [loanId], references: [id])
  paymentNumber      Int
  dueDate            DateTime
  totalAmount        Float
  principalAmount    Float
  interestAmount     Float
  remainingPrincipal Float
  isPaid             Boolean  @default(false)
  paymentId          Int?     @unique
  payment            Payment? @relation(fields: [paymentId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Loan Application model
model LoanApplication {
  id              Int          @id @default(autoincrement())
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  loanProductId   Int
  loanProduct     LoanProduct  @relation(fields: [loanProductId], references: [id])
  amount          Float
  term            Int
  purpose         String?
  status          String       @default("PENDING")
  rejectionReason String?
  creditScore     Int?
  monthlyIncome   Float?
  existingDebts   Float?
  reviewedBy      Int?
  reviewer        User?        @relation("LoanReviewer", fields: [reviewedBy], references: [id])
  reviewDate      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cooperativeId   Int?
  cooperative     Cooperative? @relation(fields: [cooperativeId], references: [id])
}

// Loan History model
model LoanHistory {
  id          Int      @id @default(autoincrement())
  loanId      Int
  loan        Loan     @relation(fields: [loanId], references: [id])
  action      String
  details     String?
  performedBy Int
  performer   User     @relation(fields: [performedBy], references: [id])
  createdAt   DateTime @default(now())
}

// Delinquency Report model
model DelinquencyReport {
  id                    Int          @id @default(autoincrement())
  reportDate            DateTime
  totalLoans            Int
  delinquentLoans       Int
  delinquencyRate       Float
  totalDelinquentAmount Float
  cooperativeId         Int?
  cooperative           Cooperative? @relation(fields: [cooperativeId], references: [id])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

// Loan Performance Report model
model LoanPerformanceReport {
  id                      Int          @id @default(autoincrement())
  reportDate              DateTime
  totalActiveLoans        Int
  totalLoanAmount         Float
  totalInterestEarned     Float
  totalPrincipalPaid      Float
  totalPenaltiesCollected Float
  cooperativeId           Int?
  cooperative             Cooperative? @relation(fields: [cooperativeId], references: [id])
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

// Enums
enum UserRole {
  ADMIN
  BOARD_MEMBER
  MANAGER
  CREDIT_OFFICER
  ACCOUNTANT
  TELLER
  COMPLIANCE_OFFICER
  MEMBER
  MEMBERSHIP_OFFICER
  SECURITY_OFFICER
  MARKETING_OFFICER
  PARTNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  PAID
  DEFAULTED
  RESTRUCTURED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  DEDUCTION
  CHECK
  ONLINE_PAYMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum SavingsType {
  REGULAR
  FIXED
  RETIREMENT
  EDUCATION
  EMERGENCY
}

enum SavingsStatus {
  ACTIVE
  INACTIVE
  CLOSED
  DORMANT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  LOAN_DISBURSEMENT
  LOAN_PAYMENT
  INTEREST_EARNED
  FEE
  DIVIDEND
  // Damayan transaction types
  DAMAYAN_CONTRIBUTION
  DAMAYAN_DISBURSEMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum DocumentType {
  ID
  PROOF_OF_INCOME
  PROOF_OF_ADDRESS
  LOAN_AGREEMENT
  COLLATERAL
  OTHER
}

enum NotificationType {
  LOAN_STATUS
  PAYMENT_DUE
  PAYMENT_RECEIVED
  ACCOUNT_UPDATE
  SYSTEM
  MARKETING
  // Damayan notification types
  DAMAYAN_REQUEST
  DAMAYAN_APPROVAL
  DAMAYAN_DISBURSEMENT
  DAMAYAN_CONTRIBUTION
}

enum CooperativeProfileType {
  PRIMARY
  FEDERATION
  COOPERATIVE_BANK
  INSURANCE_COOPERATIVE
  ELECTRIC_COOPERATIVE
  UNION
  NEWLY_REGISTERED
  PRIMARY_MICRO
}

enum ComplianceFilingStatus {
  DRAFT
  INTERNAL_REVIEW
  ATTESTED
  SUBMITTED
  UNDER_EVALUATION
  DEFICIENCY_NOTED
  CORRECTED_RESUBMISSION
  APPROVED
  COC_ISSUED
}

enum ComplianceModuleType {
  CAPR
  AFS
  OFFICERS_TRAINING
  SOCIAL_AUDIT
  PERFORMANCE_AUDIT
  SEMI_ANNUAL_MEDIATION
  ATIR
  ABR
  SWORN_STATEMENT
  MCO_LIST
  FINANCIAL_STATUS_REPORT
}

enum ComplianceModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum FilingChannel {
  CAPRIS
  MANUAL
  EMAIL
}

enum AssetSizeClass {
  MICRO
  SMALL
  MEDIUM
  LARGE
}

model ComplianceAuthorizedRep {
  id                 Int        @id @default(autoincrement())
  cooperativeId      Int
  cooperative        Cooperative @relation(fields: [cooperativeId], references: [id])
  fullName           String
  position           String
  governmentIdType   String
  governmentIdNo     String
  mobile             String
  email              String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model ComplianceFiling {
  id                  Int                      @id @default(autoincrement())
  cooperativeId       Int
  cooperative         Cooperative              @relation(fields: [cooperativeId], references: [id])
  coverageYear        Int
  registrationNo      String
  profileType         CooperativeProfileType
  hasCTE              Boolean                  @default(false)
  filingStatus        ComplianceFilingStatus   @default(DRAFT)
  filingChannel       FilingChannel            @default(CAPRIS)
  assetSizeClass      AssetSizeClass?
  auditorCeaNo        String?
  authorizedRepId     Int?
  authorizedRep       ComplianceAuthorizedRep? @relation(fields: [authorizedRepId], references: [id])
  membershipTotal     Int                      @default(0)
  membershipRegular   Int                      @default(0)
  membershipAssociate Int                      @default(0)
  completeness        Json?
  submittedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  modules             ComplianceFilingModule[]
  deficiencies        ComplianceDeficiency[]
  penalties           CompliancePenalty[]
  swornStatement      ComplianceSwornStatement?
}

model ComplianceFilingModule {
  id              Int                    @id @default(autoincrement())
  filingId        Int
  filing          ComplianceFiling       @relation(fields: [filingId], references: [id])
  moduleType      ComplianceModuleType
  isRequired      Boolean                @default(true)
  status          ComplianceModuleStatus @default(NOT_STARTED)
  evidenceUrl     String?
  evidenceVersion Int                    @default(1)
  updatedAt       DateTime               @updatedAt
}

model ComplianceDeficiency {
  id           Int               @id @default(autoincrement())
  filingId     Int
  filing       ComplianceFiling  @relation(fields: [filingId], references: [id])
  noticeDate   DateTime
  deadlineDate DateTime
  details      String
  resolved     Boolean           @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
}

model CompliancePenalty {
  id         Int               @id @default(autoincrement())
  filingId   Int
  filing     ComplianceFiling  @relation(fields: [filingId], references: [id])
  daysLate   Int
  amount     Float
  assessedAt DateTime          @default(now())
}

model ComplianceSwornStatement {
  id                   Int               @id @default(autoincrement())
  filingId             Int               @unique
  filing               ComplianceFiling  @relation(fields: [filingId], references: [id])
  adheresRA9520        Boolean
  adheresCDAMC2024_16  Boolean
  conflictOfInterest   Boolean
  disloyalty           Boolean
  confidentiality      Boolean
  signatoryName        String
  signatoryPosition    String
  signedAt             DateTime
  evidenceUrl          String?
}

model ComplianceRequirementProfile {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  expression  Json
  modules     ComplianceRequirementModule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ComplianceRequirementModule {
  id          Int                        @id @default(autoincrement())
  profileId   Int
  profile     ComplianceRequirementProfile @relation(fields: [profileId], references: [id])
  moduleType  ComplianceModuleType
  condition   Json?
  isRequired  Boolean                    @default(true)
}

// Damayan Fund model
model DamayanFund {
  id                Int                 @id @default(autoincrement())
  name              String
  description       String?
  balance           Float               @default(0)
  status            DamayanFundStatus   @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdById       Int
  createdBy         User                @relation("FundCreator", fields: [createdById], references: [id])
  cooperativeId     Int?
  cooperative       Cooperative?        @relation(fields: [cooperativeId], references: [id])
  contributions     DamayanContribution[]
  assistanceRequests DamayanAssistance[]
}

// Damayan Contribution model
model DamayanContribution {
  id                Int                 @id @default(autoincrement())
  amount            Float
  contributionDate  DateTime            @default(now())
  contributionType  DamayanContributionType
  status            TransactionStatus   @default(COMPLETED)
  userId            Int
  user              User                @relation(fields: [userId], references: [id])
  damayanFundId     Int
  damayanFund       DamayanFund         @relation(fields: [damayanFundId], references: [id])
  transactionId     Int?                @unique
  transaction       Transaction?        @relation(fields: [transactionId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

// Damayan Assistance model
model DamayanAssistance {
  id                Int                 @id @default(autoincrement())
  requestDate       DateTime            @default(now())
  amount            Float?
  reason            String
  status            DamayanAssistanceStatus @default(PENDING)
  approvalDate      DateTime?
  disbursementDate  DateTime?
  rejectionReason   String?
  userId            Int
  user              User                @relation(fields: [userId], references: [id])
  damayanFundId     Int
  damayanFund       DamayanFund         @relation(fields: [damayanFundId], references: [id])
  approvedById      Int?
  approvedBy        User?               @relation("DamayanApprover", fields: [approvedById], references: [id])
  transactionId     Int?                @unique
  transaction       Transaction?        @relation(fields: [transactionId], references: [id])
  documents         DamayanDocument[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

// Damayan Document model
model DamayanDocument {
  id                Int                 @id @default(autoincrement())
  name              String
  fileUrl           String
  documentType      DamayanDocumentType
  assistanceId      Int
  assistance        DamayanAssistance   @relation(fields: [assistanceId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

// Damayan User Settings model
model DamayanUserSettings {
  id                Int                 @id @default(autoincrement())
  userId            Int                 @unique
  user              User                @relation(fields: [userId], references: [id])
  autoContribute    Boolean             @default(false)
  contributionType  String              @default("FIXED") // FIXED or PERCENTAGE
  fixedAmount       Float               @default(10)
  percentageAmount  Float               @default(1)
  monthlyContribution Boolean           @default(false)
  monthlyAmount     Float               @default(50)
  receiveNotifications Boolean          @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

// Damayan enums
enum DamayanFundStatus {
  ACTIVE
  INACTIVE
}

enum DamayanContributionType {
  AUTOMATIC
  MANUAL
  TRANSACTION_BASED
}

enum DamayanAssistanceStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

enum DamayanDocumentType {
  MEDICAL_BILL
  DEATH_CERTIFICATE
  HOSPITAL_RECORD
  PROOF_OF_RELATIONSHIP
  OTHER
}
